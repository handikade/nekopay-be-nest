generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// #region USER

enum UserRole {
  admin
  user
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username     String   @unique @db.VarChar(50)
  email        String   @unique @db.VarChar(255)
  phone_number String?  @unique @db.VarChar(20)
  password     String
  role         UserRole @default(user)

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("users")
}

// #endregion USER

// #region TAX

enum TaxType {
  INCLUSIVE
  EXCLUSIVE
}

model Tax {
  id   String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code String  @unique @db.VarChar(50)
  rate Decimal @db.Decimal(5, 4)
  type TaxType
  name String  @db.VarChar(100)

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("taxes")
}

// #endregion TAX

// #region BANK

model Bank {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code String @unique @db.VarChar(50)
  name String @db.VarChar(255)

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("banks")
}

// #endregion BANK

// #region CONTACT

model Contact {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partner_id   String  @db.Uuid
  name         String  @db.VarChar(255)
  email        String? @db.VarChar(255)
  phone_number String  @db.VarChar(20)

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  partner Partner @relation(fields: [partner_id], references: [id])

  @@map("contacts")
}

// #endregion CONTACT

// #region PARTNER

enum PartnerEntity {
  CV
  PT
  KOPERASI
  INDIVIDUAL
}

enum PartnerType {
  SUPPLIER
  CLIENT
}

model Partner {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String        @db.VarChar(255)
  type            PartnerType
  legal_entity    PartnerEntity
  company_email   String        @unique @db.VarChar(255)
  company_phone   String        @db.VarChar(20)
  provinsi_id     String?       @db.VarChar(10)
  provinsi_label  String?       @db.VarChar(100)
  kota_id         String?       @db.VarChar(10)
  kota_label      String?       @db.VarChar(100)
  kecamatan_id    String?       @db.VarChar(10)
  kecamatan_label String?       @db.VarChar(100)
  kelurahan_id    String?       @db.VarChar(10)
  kelurahan_label String?       @db.VarChar(100)
  address         String?       @db.VarChar(255)
  postal_code     String?       @db.VarChar(10)

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  partner_bank_accounts PartnerBankAccount[]
  contacts              Contact[]

  @@map("partners")
}

model PartnerBankAccount {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partner_id     String @db.Uuid
  bank_code      String @db.VarChar(50)
  bank_name      String @db.VarChar(100)
  account_number String @db.VarChar(50)
  account_name   String @db.VarChar(100)

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  partner Partner @relation(fields: [partner_id], references: [id])

  @@map("partner_bank_accounts")
}

// #endregion PARTNER
