generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// #region USER

enum UserRole {
  admin
  user
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username     String    @unique @db.VarChar(50)
  email        String    @unique @db.VarChar(255)
  phone_number String?   @unique @db.VarChar(20)
  password     String
  role         UserRole  @default(user)
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @default(now()) @updatedAt @db.Timestamptz
  partners     Partner[]
  invoices     Invoice[]

  @@map("users")
}

// #endregion USER

// #region TAX

enum TaxType {
  INCLUSIVE
  EXCLUSIVE
}

model Tax {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String        @unique @db.VarChar(50)
  rate          Decimal       @db.Decimal(5, 4)
  type          TaxType
  name          String        @db.VarChar(100)
  created_at    DateTime      @default(now()) @db.Timestamptz
  updated_at    DateTime      @default(now()) @updatedAt @db.Timestamptz
  invoice_items InvoiceItem[]

  @@map("taxes")
}

// #endregion TAX

// #region BANK

model Bank {
  id                    String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                  String               @unique @db.VarChar(50)
  name                  String               @db.VarChar(255)
  created_at            DateTime             @default(now()) @db.Timestamptz
  updated_at            DateTime             @default(now()) @updatedAt @db.Timestamptz
  partner_bank_accounts PartnerBankAccount[]

  @@map("banks")
}

// #endregion BANK

// #region PARTNER

enum PartnerEntity {
  CV
  PT
  KOPERASI
  INDIVIDUAL
}

enum PartnerType {
  SUPPLIER
  BUYER
}

model Partner {
  id                    String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  number                String?              @unique @db.VarChar(50)
  name                  String               @db.VarChar(255)
  types                 PartnerType[]
  legal_entity          PartnerEntity
  company_email         String               @unique @db.VarChar(255)
  company_phone         String               @db.VarChar(20)
  provinsi_id           String?              @db.VarChar(10)
  provinsi_label        String?              @db.VarChar(100)
  kota_id               String?              @db.VarChar(10)
  kota_label            String?              @db.VarChar(100)
  kecamatan_id          String?              @db.VarChar(10)
  kecamatan_label       String?              @db.VarChar(100)
  kelurahan_id          String?              @db.VarChar(10)
  kelurahan_label       String?              @db.VarChar(100)
  address               String?              @db.VarChar(255)
  postal_code           String?              @db.VarChar(10)
  user_id               String               @db.Uuid
  user                  User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at            DateTime             @default(now()) @db.Timestamptz
  updated_at            DateTime             @default(now()) @updatedAt @db.Timestamptz
  deleted_at            DateTime?            @db.Timestamptz
  partner_bank_accounts PartnerBankAccount[]
  contacts              PartnerContact[]
  invoices              Invoice[]

  @@map("partners")
}

model PartnerContact {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partner_id   String   @db.Uuid
  name         String   @db.VarChar(255)
  email        String?  @db.VarChar(255)
  phone_number String   @db.VarChar(20)
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz
  partner      Partner  @relation(fields: [partner_id], references: [id], onDelete: Cascade)

  @@map("partner_contacts")
}

model PartnerBankAccount {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partner_id     String   @db.Uuid
  bank_id        String   @db.Uuid
  bank           Bank     @relation(fields: [bank_id], references: [id], onDelete: Restrict)
  account_number String   @db.VarChar(50)
  account_name   String   @db.VarChar(100)
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz
  partner        Partner  @relation(fields: [partner_id], references: [id], onDelete: Cascade)

  @@map("partner_bank_accounts")
}

// #endregion PARTNER

// #region INVOICE

enum InvoiceType {
  SALES
  PURCHASE
}

enum InvoiceDocStatus {
  DRAFT
  POSTED
  PAID
  CANCELLED
}

enum InvoiceSentStatus {
  SENT
  NOT_SENT
}

model Invoice {
  id                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  number                String            @db.VarChar(50)
  type                  InvoiceType       @default(SALES)
  document_status       InvoiceDocStatus  @default(DRAFT)
  sent_status           InvoiceSentStatus @default(NOT_SENT)
  issue_date            DateTime          @db.Date
  due_date              DateTime?         @db.Date
  currency              String            @default("IDR") @db.VarChar(3)
  subtotal              Decimal           @default(0.00) @db.Decimal(12, 2)
  total_tax             Decimal           @default(0.00) @db.Decimal(12, 2)
  total_discount        Decimal           @default(0.00) @db.Decimal(12, 2)
  grand_total           Decimal           @default(0.00) @db.Decimal(12, 2)
  notes                 String?           @db.Text
  user_id               String            @db.Uuid
  user                  User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  partner_id            String            @db.Uuid
  partner               Partner           @relation(fields: [partner_id], references: [id], onDelete: Restrict)
  partner_name          String            @db.VarChar(255)
  partner_company_email String            @db.VarChar(255)
  partner_company_phone String            @db.VarChar(20)
  partner_address       String?           @db.VarChar(255)
  partner_snapshot_at   DateTime          @default(now()) @db.Timestamptz
  items                 InvoiceItem[]
  created_at            DateTime          @default(now()) @db.Timestamptz
  updated_at            DateTime          @default(now()) @updatedAt @db.Timestamptz
  deleted_at            DateTime?         @db.Timestamptz

  @@unique([user_id, number])
  @@map("invoices")
}

model InvoiceItem {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  description     String   @db.VarChar(255)
  quantity        Decimal  @default(1.00) @db.Decimal(8, 2)
  unit_price      Decimal  @db.Decimal(12, 2)
  discount_rate   Decimal? @default(0.00) @db.Decimal(5, 2)
  discount_amount Decimal? @default(0.00) @db.Decimal(12, 2)
  tax_id          String?  @db.Uuid
  tax             Tax?     @relation(fields: [tax_id], references: [id], onDelete: SetNull)
  tax_rate        Decimal? @default(0.00) @db.Decimal(5, 2)
  tax_amount      Decimal? @default(0.00) @db.Decimal(12, 2)
  line_total      Decimal  @db.Decimal(12, 2)
  invoice_id      String   @db.Uuid
  invoice         Invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("invoice_items")
}

// #endregion INVOICE
